# InfluxDB設定
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_token_here

# デバッグ設定
LOG_LEVEL=INFO          # DEBUG, INFO, WARNING, ERROR, CRITICAL
DEBUG_FRAME_PARSING=false  # true or false
SUPPRESS_SYNC_ERRORS=false   # フレーム同期エラーログをDEBUGとして表示するか (true or false)
SUPPRESS_DISCARD_LOGS=false  # データ破棄ログをDEBUGとして表示するか (true or false)

# Dry-run モード: InfluxDB 書き込み・スリープコマンド・画像保存をスキップしてログ出力のみ
# Phase2 検証など DB 不要な動作確認に使用する (true or false)
DRY_RUN=false

# その他の環境変数
# PYTEST_CURRENT_TEST=      # テスト環境の検出用（コメントアウト）
